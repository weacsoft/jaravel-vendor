{
  "groups": [
    {
      "name": "jaravel.jwt",
      "type": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties"
    }
  ],
  "properties": [
    {
      "name": "jaravel.jwt.blacklist-enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用黑名单（登出踢 token），默认关闭，关闭时为标准 JWT",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": false
    },
    {
      "name": "jaravel.jwt.blacklist-prefix",
      "type": "java.lang.String",
      "description": "黑名单缓存键前缀",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": "jwt:blacklist:"
    },
    {
      "name": "jaravel.jwt.blacklist-store",
      "type": "java.lang.String",
      "description": "黑名单使用的缓存 store 名称，默认 array",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": "array"
    },
    {
      "name": "jaravel.jwt.grace-header",
      "type": "java.lang.String",
      "description": "宽限期续期时新 token 的响应头名称",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": "X-New-Token"
    },
    {
      "name": "jaravel.jwt.grace-period-seconds",
      "type": "java.lang.Long",
      "description": "宽限期秒数，默认 0（关闭）",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": 0
    },
    {
      "name": "jaravel.jwt.header",
      "type": "java.lang.String",
      "description": "请求头名",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": "Authorization"
    },
    {
      "name": "jaravel.jwt.prefix",
      "type": "java.lang.String",
      "description": "token 前缀",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": "Bearer "
    },
    {
      "name": "jaravel.jwt.refresh-enabled",
      "type": "java.lang.Boolean",
      "description": "是否启用 token 自动刷新（续期），默认启用",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": true
    },
    {
      "name": "jaravel.jwt.refresh-ttl",
      "type": "java.lang.Long",
      "description": "refresh token 有效期（毫秒），默认 7 天",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": 0
    },
    {
      "name": "jaravel.jwt.secret",
      "type": "java.lang.String",
      "description": "签名密钥（生产环境务必更换）",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": "jaravel-secret-key-change-this-in-production-32bytes"
    },
    {
      "name": "jaravel.jwt.ttl",
      "type": "java.lang.Long",
      "description": "access token 有效期（毫秒），默认 1 小时",
      "sourceType": "com.weacsoft.jaravel.vendor.jwt.autoconfigure.JwtProperties",
      "defaultValue": 3600000
    }
  ],
  "hints": []
}